# Universal .htaccess for Cimaise CMS
# Works with: subdomain, subdirectory, or root installation
# DocumentRoot can point to this folder (not public/)

# PHP Upload Limits Override (per Apache)
<IfModule mod_php.c>
    php_value upload_max_filesize 32M
    php_value post_max_size 32M
    php_value max_file_uploads 20
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value memory_limit 256M
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block access to sensitive files
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^\.htaccess$ - [F,L]
    RewriteRule \.sqlite$ - [F,L]
    RewriteRule \.log$ - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^package(-lock)?\.json$ - [F,L]

    # Block access to sensitive directories
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^storage/ - [F,L]
    RewriteRule ^app/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^config/ - [F,L]
    RewriteRule ^bin/ - [F,L]

    # Never expose user media through the /public alias. /media/* must pass
    # through MediaController, which enforces publication/password/NSFW access.
    RewriteRule ^public/media/ - [F,L]

    # If request is for public/ directory, serve directly (for direct access)
    RewriteCond %{REQUEST_URI} ^/public/
    RewriteRule ^public/(.*)$ public/$1 [L]

    # Static asset fast path (M5): map known static paths to public/ BEFORE the
    # PHP catch-all so Apache serves them directly instead of routing them
    # through index.php (which used to md5_file() the whole file per request).
    #
    # Existence guard without DOCUMENT_ROOT assumptions (works for root,
    # subdomain AND subdirectory installs): the rewrite restarts per-directory
    # processing; if public/<path> exists Apache serves it (the catch-all's !-f
    # fails), if it does not exist the catch-all routes to index.php and the app
    # answers its normal 404.
    #
    # SECURITY: /media/* and fonts/typography.css are deliberately NOT listed —
    # they MUST go through PHP (album password/NSFW access control, dynamic CSS).
    # site.webmanifest is a dynamic PHP route, also excluded. /plugins/* is
    # excluded too: plugin assets are served from the root plugins/ directory
    # (see plugins_url()), not from public/plugins/. This is a strict whitelist:
    # nothing outside it gains direct-serve behavior.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^((?:assets|build)/.+|fonts/(?!typography\.css).+|favicon\.ico|favicon-[0-9]+x[0-9]+\.png|favicon-source\.png|apple-touch-icon\.png|android-chrome-[0-9]+x[0-9]+\.png|icon-[0-9]+x[0-9]+\.png|robots\.txt|sitemap[^/]*\.xml|sw\.js|offline\.html)$ public/$1 [L]

    # Route everything through index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L]
</IfModule>

# Fallback: If mod_rewrite is not available
<IfModule !mod_rewrite.c>
    DirectoryIndex index.php
    ErrorDocument 404 /index.php
</IfModule>

# Deny access to hidden files (dotfiles)
<FilesMatch "^\.">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Deny access to sensitive file extensions
<FilesMatch "\.(env|sqlite|log|sql|bak|backup|old|orig|tmp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Security headers
# unset-then-set guarantees a single header value even when the PHP
# SecurityHeadersMiddleware already emitted the same header on dynamic responses
# (avoids duplicate "DENY, DENY"), while still covering Apache-served static files.
<IfModule mod_headers.c>
    Header always unset X-Content-Type-Options
    Header always set X-Content-Type-Options "nosniff"
    Header always unset X-Frame-Options
    Header always set X-Frame-Options "DENY"
    Header always unset X-XSS-Protection
    Header always set X-XSS-Protection "1; mode=block"
</IfModule>

# Disable directory listing
Options -Indexes

# Set default charset
AddDefaultCharset UTF-8


# Protect sensitive manifest and config files (Apache 2.2/2.4 compatible)
# Note: .env files already covered by the dotfiles rule above
<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Protect sensitive files (Apache 2.4+)
<IfModule mod_authz_core.c>
    <FilesMatch "^(\.env|composer\.(json|lock)|package(-lock)?\.json)$">
        Require all denied
    </FilesMatch>
</IfModule>
# Protect sensitive files (Apache 2.2)
<IfModule !mod_authz_core.c>
    <FilesMatch "^(\.env|composer\.(json|lock)|package(-lock)?\.json)$">
        Order Allow,Deny
        Deny from all
    </FilesMatch>
</IfModule>
