{# Shared PWA runtime: broken-image self-heal + data-fallback hide handler
   + Service Worker registration (cache tied to app_version via ?v=).
   Included by BOTH _layout.twig and _layout_modern.twig so every
   frontend layout gets the same offline/cache/self-heal behaviour. #}
    <script nonce="{{ csp_nonce() }}">
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('img[data-fallback="hide"]').forEach(function(img) {
            img.addEventListener('error', function() {
                // Don't hide an image the self-heal below is recovering: it sets
                // data-swHealed in the capture phase (before this target-phase
                // listener), so a successful retry stays visible. If the retry
                // also fails, the browser's broken-image glyph is clearer
                // feedback than a silently-vanished slot.
                if (this.dataset.swHealed) return;
                this.style.display = 'none';
            });
        });
    });

    // Self-heal broken media images. If a /media/ photo fails to load — e.g. a
    // stale or corrupt Service-Worker/HTTP cache entry — we ask the SW to evict
    // that URL and retry ONCE. This means a user who ever cached a bad response
    // recovers automatically on the next view, without ever having to clear the
    // cache by hand. Capture phase + window: <img> 'error' events don't bubble,
    // and this also covers images injected later (e.g. the home marquee).
    window.addEventListener('error', function(e) {
        var img = e.target;
        if (!img || img.tagName !== 'IMG' || img.dataset.swHealed) return;
        var src = img.currentSrc || img.src || '';
        if (src.indexOf('/media/') === -1) return;
        img.dataset.swHealed = '1';
        // The failed resource is usually a <picture> <source> variant (avif/webp/
        // jxl) — img.currentSrc points at it. Reassigning img.src alone won't help:
        // the browser keeps honouring the matching <source>. So drop the <source>
        // elements (the bare <img src> is already the universally-decodable JPEG
        // baseline) and reload that, cache-busted. Also evict the failed variant
        // from the SW cache so a later load re-fetches it fresh.
        var failed = src.split('#')[0];
        if (navigator.serviceWorker && navigator.serviceWorker.controller) {
            navigator.serviceWorker.controller.postMessage({ type: 'EVICT', url: failed });
        }
        var pic = img.parentElement;
        if (pic && pic.tagName === 'PICTURE') {
            pic.querySelectorAll('source').forEach(function(s) { s.remove(); });
        }
        var base = (img.getAttribute('src') || failed).split('#')[0];
        img.style.display = '';
        img.src = base + (base.indexOf('?') === -1 ? '?' : '&') + 'swcb=' + Date.now();
    }, true);
    </script>

    {# PWA Service Worker Registration #}
    <script nonce="{{ csp_nonce() }}">
    // Register Service Worker for offline support and PWA features
    if ('serviceWorker' in navigator) {
      const pwaDebug = {{ app_debug|default(false) ? 'true' : 'false' }};
      const pwaLog = pwaDebug ? console.log.bind(console) : function() {};

      window.addEventListener('load', function() {
        navigator.serviceWorker.register('{{ base_path }}/sw.js?v={{ app_version|default('0')|e('url') }}')
          .then(function(registration) {
            pwaLog('[PWA] Service Worker registered:', registration.scope);

            // Check for updates periodically (less aggressive)
            const updateIntervalMs = 15 * 60 * 1000;
            setInterval(function() {
              registration.update();
            }, updateIntervalMs);
            document.addEventListener('visibilitychange', function() {
              if (document.visibilityState === 'visible') {
                registration.update();
              }
            });

            // Handle updates
            registration.addEventListener('updatefound', function() {
              const newWorker = registration.installing;
              newWorker.addEventListener('statechange', function() {
                if (newWorker.state === 'installed' && navigator.serviceWorker.controller) {
                  // New content available, notify user
                  pwaLog('[PWA] New content available, please refresh.');
                  // Show a non-blocking update banner
                  if (!document.getElementById('pwa-update-banner')) {
                    const banner = document.createElement('div');
                    banner.id = 'pwa-update-banner';
                    banner.className = 'fixed bottom-4 left-1/2 z-[9999] flex -translate-x-1/2 items-center gap-3 rounded-full bg-black/90 px-4 py-2 text-xs text-white shadow-lg';
                    banner.setAttribute('role', 'status');
                    banner.setAttribute('aria-live', 'polite');
                    banner.setAttribute('aria-label', 'Update notification');
                    banner.innerHTML = '<span>New version available</span>';
                    const refreshBtn = document.createElement('button');
                    refreshBtn.type = 'button';
                    refreshBtn.className = 'rounded-full bg-white/10 px-3 py-1 text-xs hover:bg-white/20';
                    refreshBtn.setAttribute('aria-label', 'Refresh to update now');
                    refreshBtn.textContent = 'Refresh';
                    refreshBtn.addEventListener('click', function() {
                      newWorker.postMessage({ type: 'SKIP_WAITING' });
                    });
                    const dismissBtn = document.createElement('button');
                    dismissBtn.type = 'button';
                    dismissBtn.className = 'rounded-full bg-white/10 px-3 py-1 text-xs hover:bg-white/20';
                    dismissBtn.setAttribute('aria-label', 'Dismiss update notification');
                    dismissBtn.textContent = 'Dismiss';
                    dismissBtn.addEventListener('click', function() {
                      banner.remove();
                    });
                    banner.appendChild(refreshBtn);
                    banner.appendChild(dismissBtn);
                    document.body.appendChild(banner);
                    setTimeout(function() {
                      if (banner.parentNode) {
                        banner.remove();
                      }
                    }, 30000);
                  }
                }
              });
            });
          })
          .catch(function(error) {
            pwaLog('[PWA] Service Worker registration failed:', error);
          });

        // Reload page when new service worker takes control
        let refreshing = false;
        navigator.serviceWorker.addEventListener('controllerchange', function() {
          if (!refreshing) {
            refreshing = true;
            window.location.reload();
          }
        });
      });
    }
    </script>
