{% extends 'frontend/_layout.twig' %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
  /* ===== Minimal Index — ruled-list galleries listing ===== */
  .mnx-page { background: #fafafa; min-height: 60vh; }
  html.dark .mnx-page { background: #0a0a0a; }

  .mnx { max-width: 48rem; margin: 0 auto; padding: 0 1.25rem; }

  /* Masthead: generous top air, quiet typography */
  .mnx-hero { padding: 6.5rem 0 4rem; }
  @media (min-width: 1024px) { .mnx-hero { padding: 9rem 0 5.5rem; } }
  .mnx-kicker { font-size: .68rem; letter-spacing: .26em; text-transform: uppercase; color: #8c8c8c; font-weight: 500; }
  html.dark .mnx-kicker { color: #7c7c80; }
  .mnx-heading { margin-top: .9rem; font-size: clamp(1.9rem, 4vw, 2.75rem); line-height: 1.1; font-weight: 300; letter-spacing: -.02em; color: #171717; }
  html.dark .mnx-heading { color: #f5f5f4; }
  .mnx-sub { margin-top: 1.1rem; max-width: 46ch; font-size: .95rem; line-height: 1.75; color: #737373; }
  html.dark .mnx-sub { color: #9c9c9e; }

  /* Ruled list */
  .mnx-index { padding-bottom: 9rem; }
  .mnx-row { display: flex; align-items: baseline; justify-content: space-between; gap: 1.5rem; padding: 1.4rem 0; border-top: 1px solid #e5e5e5; cursor: pointer; }
  html.dark .mnx-row { border-top-color: #262626; }
  .mnx-row:last-of-type { border-bottom: 1px solid #e5e5e5; }
  html.dark .mnx-row:last-of-type { border-bottom-color: #262626; }
  .mnx-row:focus-visible { outline: 2px solid #737373; outline-offset: 4px; }

  .mnx-title { min-width: 0; font-size: 1.25rem; line-height: 1.35; font-weight: 400; letter-spacing: -.01em; color: #1c1c1c; overflow-wrap: break-word; transition: transform .25s cubic-bezier(.22,1,.36,1); }
  html.dark .mnx-title { color: #ededec; }

  .mnx-meta { flex: none; text-align: right; font-size: .8rem; line-height: 1.5; font-variant-numeric: tabular-nums; color: #8c8c8c; transition: color .2s ease-out; white-space: nowrap; }
  html.dark .mnx-meta { color: #7c7c80; }
  .mnx-meta-item { display: inline-block; }
  .mnx-meta-item + .mnx-meta-item::before { content: '\00B7'; margin: 0 .65em; color: #c4c4c2; }
  html.dark .mnx-meta-item + .mnx-meta-item::before { color: #4c4c4e; }
  .mnx-flag i { font-size: .68rem; }

  @media (max-width: 560px) {
    .mnx-row { flex-direction: column; gap: .35rem; align-items: flex-start; }
    .mnx-meta { text-align: left; }
  }

  @media (hover: hover) and (pointer: fine) {
    .mnx-row:hover .mnx-title { transform: translateX(8px); }
    .mnx-row:hover .mnx-meta { color: #404040; }
    html.dark .mnx-row:hover .mnx-meta { color: #c8c8ca; }
  }

  /* Fixed bottom cover strip (fine pointers only) */
  #mnx-strip { display: none; }
  @media (hover: hover) and (pointer: fine) {
    #mnx-strip { display: block; position: fixed; left: 0; right: 0; bottom: 0; height: min(200px, 30vh); z-index: 45; overflow: hidden; pointer-events: none; background: #161618; box-shadow: 0 -18px 48px -18px rgba(18,18,20,.4); transform: translateY(102%); transition: transform .25s cubic-bezier(.22,1,.36,1); will-change: transform; }
    #mnx-strip.is-on { transform: translateY(0); }
    #mnx-strip img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .mnx-strip-empty { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; color: #6b6b6e; font-size: 1.6rem; background: #1d1d1f; }
    .mnx-strip-veil { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; gap: .6rem; background: rgba(12,12,14,.55); color: #f5f5f4; font-size: 1.25rem; }
  }

  /* Empty state (server-side: no published galleries) */
  .mnx-empty { padding: 4rem 0 9rem; border-top: 1px solid #e5e5e5; }
  html.dark .mnx-empty { border-top-color: #262626; }
  .mnx-empty-title { font-size: 1.4rem; font-weight: 300; letter-spacing: -.01em; color: #1c1c1c; }
  html.dark .mnx-empty-title { color: #ededec; }
  .mnx-empty-text { margin-top: .8rem; max-width: 46ch; font-size: .92rem; line-height: 1.7; color: #737373; }
  html.dark .mnx-empty-text { color: #8c8c8c; }

  /* Entrance: CSS-only stagger; content is visible without JS, this only enhances */
  @media (prefers-reduced-motion: no-preference) {
    .mnx-row { animation: mnxRise .45s cubic-bezier(.22,1,.36,1) both; }
    .mnx-row:nth-child(1) { animation-delay: .04s; }
    .mnx-row:nth-child(2) { animation-delay: .08s; }
    .mnx-row:nth-child(3) { animation-delay: .12s; }
    .mnx-row:nth-child(4) { animation-delay: .16s; }
    .mnx-row:nth-child(5) { animation-delay: .2s; }
    .mnx-row:nth-child(6) { animation-delay: .24s; }
    .mnx-row:nth-child(7) { animation-delay: .28s; }
    .mnx-row:nth-child(8) { animation-delay: .32s; }
    .mnx-row:nth-child(n+9) { animation-delay: .36s; }
  }
  @keyframes mnxRise {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mnx-row, .mnx-title, .mnx-meta, #mnx-strip { animation: none !important; transition: none !important; }
  }
</style>
{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
  {% include 'frontend/_breadcrumbs.twig' %}
</div>

<div class="mnx-page">
  <!-- Masthead -->
  <header class="mnx">
    <div class="mnx-hero">
      <p class="mnx-kicker">{{ trans('galleries.tpl.index_label', {}, 'Index') }}</p>
      <h1 class="mnx-heading">{{ page_texts.title|default(trans('galleries.title'))|e }}</h1>
      {% if page_texts.subtitle|default(trans('galleries.subtitle')) %}
      <p class="mnx-sub">{{ page_texts.subtitle|default(trans('galleries.subtitle'))|e }}</p>
      {% endif %}
    </div>
  </header>

  {% if filter_settings.enabled|default(false) %}{% include 'frontend/_galleries_filters.twig' %}{% endif %}

  <!-- Ruled index -->
  <main class="mnx mnx-index">
    <div id="galleries-grid">
      {% for album in albums %}
        {% set is_locked = album.is_locked|default(false) %}
        {% set show_nsfw_overlay = album.is_nsfw and not ((nsfw_consent|default(false)) or (is_admin|default(false))) %}
        {% set should_blur_cover = show_nsfw_overlay or is_locked %}
        {% set cover_raw = '' %}
        {% if album.cover_image %}
          {% set cover_raw = should_blur_cover ? album.cover_image.blur_path|default('') : album.cover_image.preview_path|default('') %}
        {% endif %}
        {% set cover_url = cover_raw ? ((cover_raw starts with '/') ? (base_path ~ cover_raw) : cover_raw) : '' %}
        {% set overlay = show_nsfw_overlay ? 'nsfw' : (is_locked ? 'lock' : '') %}
        {% set year = album.shoot_date|default(album.published_at|default(''))|slice(0, 4) %}
        <article class="mnx-row gallery-card"
                 role="link"
                 tabindex="0"
                 data-album-id="{{ album.id }}"
                 data-nsfw="{{ album.is_nsfw and not is_admin ? '1' : '0' }}"
                 data-password-protected="{{ album.is_password_protected ? '1' : '0' }}"
                 data-album-url="{{ base_path }}/album/{{ album.slug }}"
                 data-action="open-album"
                 data-mnx-cover="{{ cover_url|e('html_attr') }}"
                 data-mnx-overlay="{{ overlay }}"
                 data-mnx-alt="{{ album.cover_image.alt_text|default(album.title)|e('html_attr') }}"
                 aria-label="{{ album.title|e('html_attr') }}">
          <h2 class="mnx-title">{{ album.title|e }}</h2>
          <p class="mnx-meta">
            {%- if year matches '/^\\d{4}$/' %}<span class="mnx-meta-item">{{ year|e }}</span>{% endif -%}
            {%- if album.category_name %}<span class="mnx-meta-item">{{ album.category_name|e }}</span>{% endif -%}
            {%- if album.images_count > 0 %}<span class="mnx-meta-item">{{ album.images_count }} {{ trans('galleries.tpl.photos_label', {}, 'photos') }}</span>{% endif -%}
            {%- if album.is_password_protected %}<span class="mnx-meta-item mnx-flag"><i class="fas fa-lock" aria-hidden="true"></i><span class="sr-only">{{ trans('album.password_protected') }}</span></span>{% endif -%}
            {%- if show_nsfw_overlay %}<span class="mnx-meta-item mnx-flag"><i class="fas fa-eye-slash" aria-hidden="true"></i><span class="sr-only">{{ trans('album.nsfw_warning_short') }}</span></span>{% endif -%}
          </p>
        </article>
      {% endfor %}
    </div>

    {% if albums|length == 0 %}
    <div id="empty-state" class="mnx-empty">
      <h2 class="mnx-empty-title">{{ trans('galleries.tpl.empty_title', {}, 'Nothing published yet') }}</h2>
      <p class="mnx-empty-text">{{ trans('galleries.tpl.empty_text', {}, 'New galleries will appear in this index as soon as they are published.') }}</p>
    </div>
    {% endif %}
  </main>

  <!-- Fixed bottom cover strip (desktop, fine pointers) -->
  <div id="mnx-strip" aria-hidden="true">
    <img id="mnx-strip-img" alt="" decoding="async" hidden>
    <span id="mnx-strip-empty" class="mnx-strip-empty" hidden><i class="fas fa-images"></i></span>
    <span id="mnx-strip-veil" class="mnx-strip-veil" hidden><i id="mnx-strip-veil-icon" class="fas fa-eye-slash"></i></span>
  </div>
</div>

<script nonce="{{ csp_nonce() }}">
(function () {
    'use strict';

    window.basePath = window.basePath || '{{ base_path|e('js') }}';
    {% if nsfw_consent|default(false) %}window.nsfwConsent = true;{% endif %}
    var IS_ADMIN = {{ is_admin|default(false) ? 'true' : 'false' }};
    var TEXTS = {
        photos: '{{ trans('galleries.tpl.photos_label', {}, 'photos')|e('js') }}',
        locked: '{{ trans('album.password_protected')|e('js') }}',
        nsfw: '{{ trans('album.nsfw_warning_short')|e('js') }}'
    };

    function esc(s) {
        return String(s == null ? '' : s)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#039;');
    }

    function hasNsfwConsent() {
        if (window.nsfwConsent === true) return true;
        try {
            return window.localStorage && window.localStorage.getItem('nsfw_confirmed') === 'true';
        } catch (e) { return false; }
    }

    // ---- Client-side row renderer (called by the filters partial) ----
    // Produces markup structurally identical to the server-rendered .mnx-row above.
    window.cimaiseRenderCard = function (album, index) {
        album = album || {};
        var cover = album.cover_image || {};
        var isLocked = !!album.is_locked;
        var nsfwBlocked = !!album.is_nsfw && !IS_ADMIN && !hasNsfwConsent();
        var shouldBlur = nsfwBlocked || isLocked;
        var raw = shouldBlur ? (cover.blur_path || '') : (cover.preview_path || '');
        var url = raw ? (raw.charAt(0) === '/' ? (window.basePath || '') + raw : raw) : '';
        var overlay = nsfwBlocked ? 'nsfw' : (isLocked ? 'lock' : '');
        var year = String(album.shoot_date || album.published_at || '').slice(0, 4);
        if (!/^\d{4}$/.test(year)) year = '';
        var albumUrl = (window.basePath || '') + '/album/' + encodeURIComponent(album.slug || '');
        var alt = cover.alt_text || album.title || '';

        var meta = '';
        if (year) meta += '<span class="mnx-meta-item">' + esc(year) + '</span>';
        if (album.category_name) meta += '<span class="mnx-meta-item">' + esc(album.category_name) + '</span>';
        if ((album.images_count || 0) > 0) meta += '<span class="mnx-meta-item">' + esc(album.images_count) + ' ' + esc(TEXTS.photos) + '</span>';
        if (album.is_password_protected) meta += '<span class="mnx-meta-item mnx-flag"><i class="fas fa-lock" aria-hidden="true"></i><span class="sr-only">' + esc(TEXTS.locked) + '</span></span>';
        if (nsfwBlocked) meta += '<span class="mnx-meta-item mnx-flag"><i class="fas fa-eye-slash" aria-hidden="true"></i><span class="sr-only">' + esc(TEXTS.nsfw) + '</span></span>';

        return '<article class="mnx-row gallery-card" role="link" tabindex="0"'
            + ' data-album-id="' + esc(album.id || '') + '"'
            + ' data-nsfw="' + ((album.is_nsfw && !IS_ADMIN) ? '1' : '0') + '"'
            + ' data-password-protected="' + (album.is_password_protected ? '1' : '0') + '"'
            + ' data-album-url="' + esc(albumUrl) + '"'
            + ' data-action="open-album"'
            + ' data-mnx-cover="' + esc(url) + '"'
            + ' data-mnx-overlay="' + overlay + '"'
            + ' data-mnx-alt="' + esc(alt) + '"'
            + ' aria-label="' + esc(album.title || '') + '">'
            + '<h2 class="mnx-title">' + esc(album.title || '') + '</h2>'
            + '<p class="mnx-meta">' + meta + '</p>'
            + '</article>';
    };

    // ---- Row navigation (touch devices simply navigate; gates are server-side) ----
    document.addEventListener('click', function (event) {
        var row = event.target.closest ? event.target.closest('[data-action="open-album"]') : null;
        if (!row) return;
        if (event.target.closest('a')) return;
        event.preventDefault();
        if (row.dataset.albumUrl) window.location.href = row.dataset.albumUrl;
    });
    document.addEventListener('keydown', function (event) {
        if (event.key !== 'Enter' && event.key !== ' ') return;
        if (!event.target || !event.target.closest) return;
        var row = event.target.closest('[data-action="open-album"]');
        if (!row || row !== event.target) return;
        event.preventDefault();
        if (row.dataset.albumUrl) window.location.href = row.dataset.albumUrl;
    });

    // ---- Bottom cover strip (fine pointers only) ----
    var grid = document.getElementById('galleries-grid');
    var strip = document.getElementById('mnx-strip');
    var stripImg = document.getElementById('mnx-strip-img');
    var stripEmpty = document.getElementById('mnx-strip-empty');
    var stripVeil = document.getElementById('mnx-strip-veil');
    var stripVeilIcon = document.getElementById('mnx-strip-veil-icon');
    var finePointer = window.matchMedia('(hover: hover) and (pointer: fine)');
    var activeRow = null;

    function showStrip(row) {
        var src = row.dataset.mnxCover || '';
        var overlay = row.dataset.mnxOverlay || '';
        if (src) {
            if (stripImg.getAttribute('src') !== src) stripImg.src = src;
            stripImg.alt = row.dataset.mnxAlt || '';
            stripImg.hidden = false;
            stripEmpty.hidden = true;
        } else {
            stripImg.removeAttribute('src');
            stripImg.hidden = true;
            stripEmpty.hidden = false;
        }
        if (overlay) {
            stripVeilIcon.className = overlay === 'lock' ? 'fas fa-lock' : 'fas fa-eye-slash';
            stripVeil.hidden = false;
        } else {
            stripVeil.hidden = true;
        }
        strip.classList.add('is-on');
    }

    function hideStrip() {
        activeRow = null;
        if (strip) strip.classList.remove('is-on');
    }

    if (grid && strip) {
        grid.addEventListener('pointerover', function (ev) {
            if (!finePointer.matches) return;
            var row = ev.target.closest ? ev.target.closest('.mnx-row') : null;
            if (!row) { hideStrip(); return; }
            if (row !== activeRow) {
                activeRow = row;
                showStrip(row);
            }
        });
        grid.addEventListener('pointerleave', hideStrip);
        // Keyboard parity: focusing a row reveals its cover too
        grid.addEventListener('focusin', function (ev) {
            if (!finePointer.matches) return;
            var row = ev.target.closest ? ev.target.closest('.mnx-row') : null;
            if (row) { activeRow = row; showStrip(row); }
        });
        grid.addEventListener('focusout', function (ev) {
            if (!ev.relatedTarget || !ev.relatedTarget.closest || !ev.relatedTarget.closest('.mnx-row')) hideStrip();
        });
    }

    // ---- After the filters partial re-renders the grid ----
    // (Entrance animation is CSS-driven and restarts automatically on new rows.)
    document.addEventListener('cimaise:galleries-updated', function () {
        hideStrip();
    });
})();
</script>
{% endblock %}
