{# WordPress-style admin top bar — shown on the frontend ONLY for a logged-in admin.
   Gated by the admin_logged_in global (FlashMiddleware), so it appears on every page. #}
{% if admin_logged_in|default(false) %}
<style nonce="{{ csp_nonce() }}">
  :root { --cmab-h: 38px; }
  body.has-admin-bar { padding-top: var(--cmab-h); }
  /* Push the frontend's sticky header + mega menu below the bar. */
  body.has-admin-bar #main-header { top: var(--cmab-h); }
  body.has-admin-bar #categories-mega-menu { top: calc(80px + var(--cmab-h)) !important; }

  .cm-adminbar {
    position: fixed; top: 0; left: 0; right: 0; height: var(--cmab-h); z-index: 100000;
    display: flex; align-items: stretch; justify-content: space-between;
    background: #1f2430; color: #e5e7eb; font-size: 13px; line-height: 1;
    border-bottom: 1px solid #000; box-shadow: 0 1px 0 rgba(255,255,255,.04) inset;
    -webkit-font-smoothing: antialiased; font-family: Inter, system-ui, sans-serif;
  }
  .cm-adminbar a, .cm-adminbar button {
    display: inline-flex; align-items: center; gap: 7px; padding: 0 13px;
    color: #e5e7eb; text-decoration: none; background: none; border: 0; cursor: pointer;
    height: 100%; white-space: nowrap; transition: background .15s ease, color .15s ease;
  }
  .cm-adminbar a:hover, .cm-adminbar button:hover { background: #2a3040; color: #fff; }
  .cm-adminbar .cm-grp { display: flex; align-items: stretch; }
  .cm-adminbar svg { width: 16px; height: 16px; flex: 0 0 16px; }
  .cm-adminbar .cm-brand { font-weight: 600; color: #fff; }
  .cm-adminbar .cm-brand .dot { width: 8px; height: 8px; border-radius: 9999px; background: #d70261; }
  .cm-adminbar .cm-accent:hover { color: #f59ec5; }
  .cm-adminbar .cm-name {
    display: inline-flex; align-items: center; gap: 7px; height: 100%;
    padding: 0 6px 0 14px; margin-left: 2px; color: #aeb6c4; font-weight: 500;
    border-left: 1px solid rgba(0,0,0,.45); pointer-events: none;
  }
  .cm-adminbar form { display: inline-flex; height: 100%; margin: 0; }
  #cm-cache-toast {
    position: fixed; top: calc(var(--cmab-h) + 10px); right: 14px; z-index: 100001;
    background: #111827; color: #fff; font-size: 13px; padding: 9px 14px; border-radius: 6px;
    box-shadow: 0 8px 24px rgba(0,0,0,.25); opacity: 0; transform: translateY(-6px);
    transition: opacity .2s ease, transform .2s ease; pointer-events: none;
  }
  #cm-cache-toast.show { opacity: 1; transform: none; }
  @media (max-width: 720px) {
    .cm-adminbar .cm-label { display: none; }
    .cm-adminbar a, .cm-adminbar button { padding: 0 11px; }
    .cm-adminbar .cm-brand .cm-label { display: inline; }
  }
  @media print { .cm-adminbar, #cm-cache-toast { display: none !important; } body.has-admin-bar { padding-top: 0; } }
</style>

<div class="cm-adminbar" role="navigation" aria-label="{{ trans('adminbar.label')|default('Admin bar') }}">
  <div class="cm-grp">
    <a href="{{ base_path }}/admin" class="cm-brand" title="{{ site_title }}">
      <span class="dot" aria-hidden="true"></span><span class="cm-label">{{ site_title|default('Cimaise') }}</span>
    </a>
    <a href="{{ base_path }}/admin" title="{{ trans('adminbar.dashboard')|default('Backend') }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      <span class="cm-label">{{ trans('adminbar.dashboard')|default('Backend') }}</span>
    </a>
    {% if album is defined and album.id is defined and album.id %}
    <a href="{{ base_path }}/admin/albums/{{ album.id }}/edit" title="{{ trans('adminbar.edit_album')|default('Modifica album') }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4z" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="cm-label">{{ trans('adminbar.edit_album')|default('Modifica album') }}</span>
    </a>
    {% endif %}
    <a href="{{ base_path }}/admin/albums/create" title="{{ trans('adminbar.new_album')|default('Nuovo album') }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg>
      <span class="cm-label">{{ trans('adminbar.new_album')|default('Nuovo album') }}</span>
    </a>
  </div>

  <div class="cm-grp">
    <button type="button" id="cm-flush-cache" class="cm-accent" title="{{ trans('adminbar.clear_cache')|default('Svuota cache') }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 12a9 9 0 0 1 15-6.7L21 8" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 3v5h-5" stroke-linecap="round" stroke-linejoin="round"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16" stroke-linecap="round" stroke-linejoin="round"/><path d="M3 21v-5h5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <span class="cm-label">{{ trans('adminbar.clear_cache')|default('Svuota cache') }}</span>
    </button>
    {% if admin_name %}<span class="cm-name cm-label"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0" stroke-linecap="round"/></svg>{{ admin_name }}</span>{% endif %}
    <form method="post" action="{{ base_path }}/admin/logout">
      <input type="hidden" name="csrf" value="{{ csrf }}">
      <button type="submit" title="{{ trans('adminbar.logout')|default('Esci') }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" stroke-linecap="round" stroke-linejoin="round"/><path d="M16 17l5-5-5-5M21 12H9" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span class="cm-label">{{ trans('adminbar.logout')|default('Esci') }}</span>
      </button>
    </form>
  </div>
</div>
<div id="cm-cache-toast" role="status" aria-live="polite"></div>

<script nonce="{{ csp_nonce() }}">
  (function(){
    document.body.classList.add('has-admin-bar');
    var btn = document.getElementById('cm-flush-cache');
    var toast = document.getElementById('cm-cache-toast');
    if (!btn) return;
    function showToast(msg, ok){
      if (!toast) return;
      toast.textContent = msg;
      toast.style.background = ok ? '#111827' : '#7f1d1d';
      toast.classList.add('show');
      setTimeout(function(){ toast.classList.remove('show'); }, 2600);
    }
    btn.addEventListener('click', function(){
      btn.disabled = true;
      fetch('{{ base_path }}/admin/cache/clear', {
        method: 'POST',
        headers: {
          'X-Requested-With': 'XMLHttpRequest',
          'Accept': 'application/json',
          'X-CSRF-Token': {{ csrf|json_encode|raw }}
        },
        credentials: 'same-origin'
      }).then(function(r){ return r.ok ? r.json() : null; })
        .then(function(d){
          showToast((d && d.message) ? d.message : '{{ trans('adminbar.cache_cleared')|default('Cache svuotata')|e('js') }}', true);
        })
        .catch(function(){ showToast('{{ trans('adminbar.cache_error')|default('Errore svuotamento cache')|e('js') }}', false); })
        .then(function(){ btn.disabled = false; });
    });
  })();
</script>
{% endif %}
