{% extends "frontend/_layout.twig" %}
{% import "frontend/_lqip_macros.twig" as lqip %}
{% import "frontend/_home_photo.twig" as photo %}

{% block styles %}
{% include 'frontend/_lcp_preload.twig' %}
{{ lqip.lqip_styles()|raw }}
<style nonce="{{ csp_nonce() }}">
  .film-wrap { padding: 2.5rem 0 1rem; }
  .film-head { padding: 0 1.25rem 1.75rem; }
  .film-head .k { font-size: .72rem; letter-spacing: .2em; text-transform: uppercase; color: #d70261; font-weight: 600; }
  .film-head h1 { font-size: clamp(1.7rem,3.5vw,2.6rem); font-weight: 700; letter-spacing: -.02em; color: #111827; margin-top: .4rem; }
  .dark .film-head h1 { color: #f9fafb; }
  .film { background: #0c0c0d; padding: 14px 0; margin-bottom: 1.25rem; position: relative; }
  /* sprocket holes top & bottom */
  .film::before, .film::after { content: ""; position: absolute; left: 0; right: 0; height: 14px;
    background: repeating-linear-gradient(to right, #0c0c0d 0 10px, #e6e7eb 10px 20px, #0c0c0d 20px 30px); opacity: .0; }
  .film .holes { position: absolute; left: 0; right: 0; height: 9px; pointer-events: none;
    background-image: radial-gradient(#3a3a3c 38%, transparent 40%); background-size: 26px 9px; background-repeat: repeat-x; }
  .film .holes.top { top: 2px; } .film .holes.bot { bottom: 2px; }
  .strip { display: flex; gap: 4px; overflow-x: auto; scroll-snap-type: x proximity; padding: 0 1.25rem;
    scrollbar-width: thin; -webkit-overflow-scrolling: touch; }
  .strip::-webkit-scrollbar { height: 6px; } .strip::-webkit-scrollbar-thumb { background: #2a2a2c; border-radius: 6px; }
  .frame { position: relative; flex: 0 0 auto; height: 170px; scroll-snap-align: start; background: #000; overflow: hidden;
    outline: 1px solid rgba(255,255,255,.06); transition: transform .3s cubic-bezier(.16,1,.3,1); }
  @media (min-width: 768px){ .frame { height: 240px; } }
  .frame { width: calc(var(--ar) * 170px); }
  @media (min-width: 768px){ .frame { width: calc(var(--ar) * 240px); } }
  .frame:hover { transform: translateY(-4px); }
  .frame img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .frame .num { position: absolute; top: 6px; left: 7px; z-index: 2; font-size: .6rem; letter-spacing: .12em;
    color: #f59ec5; font-variant-numeric: tabular-nums; opacity: .85; mix-blend-mode: screen; }
  .frame .cap { position: absolute; left: 0; right: 0; bottom: 0; padding: .9rem .6rem .5rem; color: #fff; font-size: .78rem; font-weight: 600;
    background: rgba(0,0,0,.45); opacity: 0; transition: opacity .25s ease; }
  .frame:hover .cap, .frame:focus-within .cap { opacity: 1; }
  @media (prefers-reduced-motion: reduce){ .frame, .frame .cap { transition: none; } .frame:hover { transform: none; } }
</style>
{% endblock %}

{% block content %}
{% include 'frontend/home/_preloader.twig' %}
{{ do_action('frontend_home_before', {base_path: base_path}) }}
{% include 'frontend/home/_website_jsonld.twig' %}

{% if all_images|length > 0 %}
<div class="film-wrap">
  <header class="film-head">
    <p class="k">{{ home_settings.albums_subtitle|default(site_title)|e }}</p>
    <h1>{{ home_settings.hero_title|default(trans('home.hero_title'))|e }}</h1>
  </header>
  {% for strip in all_images|batch(10) %}
  <div class="film">
    <span class="holes top" aria-hidden="true"></span>
    <div class="strip">
      {% for image in strip %}
      {% set ar = (image.width|default(800) / max(1, image.height|default(600)))|round(3) %}
      {% set gidx = loop.parent.loop.index0 * 10 + loop.index0 %}
      <a class="frame" style="--ar: {{ ar }};" href="{{ base_path }}/album/{{ image.album_slug|e('html_attr') }}">
        <span class="num" aria-hidden="true">{{ '%02d'|format(loop.index) }}{{ ['A','','','',''][loop.index0 % 5] }}</span>
        {{ photo.picture(image, base_path, '40vw', gidx, 6, '', '') }}
        <span class="cap">{{ image.title|default(image.album_title|default(''))|e }}</span>
      </a>
      {% endfor %}
    </div>
    <span class="holes bot" aria-hidden="true"></span>
  </div>
  {% endfor %}
  {% include 'frontend/home/_more_cta.twig' %}
</div>
{% else %}
{% include 'frontend/home/_empty_state.twig' %}
{% endif %}

{{ do_action('frontend_home_after', {base_path: base_path}) }}
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">{{ lqip.lqip_script()|raw }}</script>
{% endblock %}
