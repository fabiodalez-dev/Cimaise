{#
  Shared responsive <picture> for home templates (DRY).
  Mirrors the srcset/LQIP/eager-load contract used by home_masonry.twig so every
  template benefits from the same performance behaviour (responsive sources,
  fetchpriority for the first images, LQIP blur for the rest).

  Params:
    image     — an item from `all_images` (album_slug, sources.webp/jpg, fallback_src,
                width, height, lqip_placeholder, title, album_title)
    base_path — global base path
    sizes     — the `sizes` attribute string for this template's layout
    idx       — loop.index0 (0-based) — first `eager` images load eagerly
    eager     — how many leading images skip LQIP / load with fetchpriority=high
    img_class — extra classes for the <img>
    img_style — extra inline style for the <img> (e.g. object-fit rules)
#}
{% macro picture(image, base_path, sizes, idx, eager, img_class, img_style) %}
  {% set webp_sources = image.sources.webp|default([]) %}
  {% set jpg_sources = image.sources.jpg|default([]) %}
  {% set img_src = image.fallback_src|default('') %}
  {% set img_url = img_src starts with '/' ? base_path ~ img_src : img_src %}
  {% set img_width = image.width|default(800) %}
  {% set img_height = image.height|default(600) %}
  {% set eager_n = eager|default(5) %}
  {% set use_lqip = idx >= eager_n and image.lqip_placeholder %}
  {# In the LQIP branch the <img> is deferred via data-src, so the <source> srcsets
     must also be deferred as data-srcset — otherwise the browser downloads the HD
     sources immediately and LQIP saves nothing. The LQIP runtime promotes
     source[data-srcset] -> srcset on load. #}
  {% set srcset_attr = use_lqip ? 'data-srcset' : 'srcset' %}
  <picture>
    {% if webp_sources|length > 0 %}
    <source type="image/webp" sizes="{{ sizes }}" {{ srcset_attr }}="{% for src in webp_sources %}{{ base_path }}{{ src }}{% if not loop.last %}, {% endif %}{% endfor %}">
    {% endif %}
    {% if jpg_sources|length > 0 %}
    <source type="image/jpeg" sizes="{{ sizes }}" {{ srcset_attr }}="{% for src in jpg_sources %}{{ base_path }}{{ src }}{% if not loop.last %}, {% endif %}{% endfor %}">
    {% endif %}
    <img
      {% if use_lqip %}src="{{ image.lqip_placeholder }}" data-src="{{ img_url|e('html_attr') }}"{% else %}src="{{ img_url|e('html_attr') }}"{% endif %}
      alt="{{ image.title|default(image.album_title)|e('html_attr') }}"
      width="{{ img_width }}"
      height="{{ img_height }}"
      class="{{ img_class|default('') }}{% if use_lqip %} lqip-blur{% endif %}"
      {% if img_style %}style="{{ img_style }}"{% endif %}
      {% if idx < eager_n %}fetchpriority="high"{% else %}loading="lazy" decoding="async"{% endif %}
    >
  </picture>
{% endmacro %}
