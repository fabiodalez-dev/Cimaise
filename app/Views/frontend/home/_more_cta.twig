{# Shared "view all galleries" call-to-action for home templates that show the initial
   image batch (no infinite scroll). Restrained: one outlined button, magenta on hover. #}
<div class="flex justify-center py-14">
  <a href="{{ base_path }}/{{ galleries_slug|default('galleries') }}"
     class="group inline-flex items-center gap-2 px-6 py-3 text-sm font-medium tracking-wide
            border border-gray-300 text-gray-800 hover:border-[#d70261] hover:text-[#d70261]
            dark:border-gray-700 dark:text-gray-200 transition-colors duration-200">
    {{ trans('home.view_all_galleries')|default(trans('nav.galleries')) }}
    <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path d="M5 12h14M13 6l6 6-6 6" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </a>
</div>
