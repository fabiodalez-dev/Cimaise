{% if all_images|length > 0 %}
{% set scroll_direction = home_settings.gallery_scroll_direction|default('vertical') %}
<section class="home-infinite-section relative mb-32 overflow-hidden {{ scroll_direction == 'horizontal' ? 'home-horizontal' : 'home-vertical' }}"
         data-scroll-direction="{{ scroll_direction }}">
  {% if scroll_direction == 'vertical' %}
  <div class="pointer-events-none absolute inset-x-0 top-0 h-10 z-20 home-veil-top"></div>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-10 z-20 home-veil-bottom"></div>
  {% else %}
  <div class="pointer-events-none absolute inset-y-0 left-0 w-10 z-20 home-veil-left"></div>
  <div class="pointer-events-none absolute inset-y-0 right-0 w-10 z-20 home-veil-right"></div>
  {% endif %}

{% macro home_pic(image, base_path, site_title, eager=false) %}
    <picture class="block w-full h-full">
      {% if image.sources is defined and image.sources.avif is defined and image.sources.avif|length %}
        <source type="image/avif" srcset="{% for s in image.sources.avif %}{% set p = s|split(' ') %}{{ p[0] starts with('/') ? (base_path ~ p[0]) : p[0] }} {{ p[1]|default('1x') }}{% if not loop.last %}, {% endif %}{% endfor %}" sizes="(min-width:1024px) 50vw, (min-width:640px) 70vw, 100vw">
      {% endif %}
      {% if image.sources is defined and image.sources.webp is defined and image.sources.webp|length %}
        <source type="image/webp" srcset="{% for s in image.sources.webp %}{% set p = s|split(' ') %}{{ p[0] starts with('/') ? (base_path ~ p[0]) : p[0] }} {{ p[1]|default('1x') }}{% if not loop.last %}, {% endif %}{% endfor %}" sizes="(min-width:1024px) 50vw, (min-width:640px) 70vw, 100vw">
      {% endif %}
      {% if image.sources is defined and image.sources.jpg is defined and image.sources.jpg|length %}
        <source type="image/jpeg" srcset="{% for s in image.sources.jpg %}{% set p = s|split(' ') %}{{ p[0] starts with('/') ? (base_path ~ p[0]) : p[0] }} {{ p[1]|default('1x') }}{% if not loop.last %}, {% endif %}{% endfor %}" sizes="(min-width:1024px) 50vw, (min-width:640px) 70vw, 100vw">
      {% endif %}
      {% set img_src = image.fallback_src|default(image.url) %}
      <img src="{{ img_src starts with('/') ? (base_path ~ img_src) : img_src }}"
           alt="{{ image.alt|default(image.album_title)|e }}"
           width="{{ image.width|default(1600) }}" height="{{ image.height|default(1067) }}"
           {# Only the lead images are eager-preloaded: the mobile list's first 2
              and the desktop seed's first 2 (see call sites). The rest of the
              desktop marquee is built lazily by home.js, so there is no longer a
              fully-duplicated hidden variant eager-fetching in parallel. #}
           {% if eager %}loading="eager" fetchpriority="high"{% else %}loading="lazy"{% endif %}
           decoding="async" class="w-full h-full object-cover block">
    </picture>
  {% endmacro %}

{% macro home_item(image, base_path, site_title, eager=false) %}
    {% set w = image.width|default(1600) %}
    {% set h = image.height|default(1067) %}
    <div class="home-item group rounded-xl overflow-hidden shadow-sm relative transition-transform hover:scale-105 duration-300" style="aspect-ratio: {{ w }} / {{ h }};">
      <a href="{{ base_path }}/album/{{ image.album_slug }}" class="block w-full h-full relative z-10" title="{{ image.album_title|default('')|e('html_attr') }}">
        {{ _self.home_pic(image, base_path, site_title, eager) }}
        <div class="absolute inset-0 bg-black/70 text-white flex items-center justify-center transform translate-y-full group-hover:translate-y-0 transition-transform duration-300">
          <span class="px-4 text-base md:text-lg lg:text-xl font-medium tracking-tight text-center">{{ image.album_title|e }}</span>
        </div>
      </a>
    </div>
  {% endmacro %}

  {% import _self as H %}

  {% set totalImages = all_images|length %}
  {% set o1 = 0 %}
  {% set o2 = (totalImages / 3)|round(0, 'floor') %}
  {% set o3 = (totalImages * 2 / 3)|round(0, 'floor') %}
  {% set col1 = all_images %}
  {% set col2 = all_images|slice(o2, totalImages - o2)|merge(all_images|slice(0, o2)) %}
  {% set col3 = all_images|slice(o3, totalImages - o3)|merge(all_images|slice(0, o3)) %}
  {% set minItems = 15 %}
  {% set repeat_times = (minItems / totalImages)|round(0, 'ceil') %}
  {% set repeat_times = repeat_times < 2 ? 2 : (repeat_times > 5 ? 5 : repeat_times) %}

  <div id="home-infinite-gallery" class="relative md:h-full">
    <div class="home-mobile-wrap">
      <div class="home-mobile">
        {% for image in all_images %}
          {# Mobile variant: eager only the first 2 (the mobile above-the-fold
             lead) so the mobile LCP is preloaded; the rest lazy. On desktop this
             variant is display:none, so only these 2 are wasted there (down from
             the previous 6). #}
          <div class="home-cell">{{ H.home_item(image, base_path, site_title, loop.index0 < 2) }}</div>
        {% endfor %}
      </div>
    </div>

    {# Desktop marquee: the tracks are populated by home.js from the JSON
       payload (#home-gallery-data) on the >=768px breakpoint. Only column/row 1
       carries a small server-rendered SEED so a desktop visitor gets an LCP
       candidate straight from the HTML; on mobile this whole variant is
       display:none, so the seed (a few cells) is all the hidden DOM weight —
       down from ~120 fully-rendered cells before. JS builds the full repeating
       loop (even number of copies, required for the -50% seamless scroll). #}
    {% set seed_count = 3 %}
    {% if scroll_direction == 'horizontal' %}
    {# Horizontal layout: 3 rows - all scroll right to prevent white space on load #}
    <div class="home-desktop-wrap home-desktop-horizontal gap-6 h-full" role="region" aria-label="Galleria foto">
      {% set rows = [col1, col2, col3] %}
      {% for row in rows %}
        {% set idx = loop.index0 %}
        {% set dur = idx == 0 ? '560s' : (idx == 1 ? '640s' : '720s') %}
        <div class="home-row" data-direction="right" style="--home-duration: {{ dur }}; --home-delay: 0s;" data-row-index="{{ idx }}">
          <div class="home-track-h">
            {% if idx == 0 %}
              {% for image in row|slice(0, seed_count) %}
                <div class="home-cell-h" data-seed="1">{{ H.home_item(image, base_path, site_title, loop.index0 < 2) }}</div>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    {% else %}
    {# Vertical layout: 3 columns - all scroll down to prevent white space on load #}
    <div class="home-desktop-wrap home-desktop-vertical gap-6 perspective h-full" role="region" aria-label="Galleria foto">
      {% set cols = [col1, col2, col3] %}
      {% for col in cols %}
        {% set idx = loop.index0 %}
        {% set dur = idx == 0 ? '600s' : (idx == 1 ? '780s' : '960s') %}
        <div class="home-col" data-direction="down" style="--home-duration: {{ dur }}; --home-delay: 0s;" data-col-index="{{ idx }}">
          <div class="home-track">
            {% if idx == 0 %}
              {% for image in col|slice(0, seed_count) %}
                <div class="home-cell" data-seed="1">{{ H.home_item(image, base_path, site_title, loop.index0 < 2) }}</div>
              {% endfor %}
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
    {% endif %}
  </div>

  {# Image data for the JS marquee builder. type="application/json" is inert
     (not executed) so it needs no CSP nonce; home.js reads it via textContent.
     This replaces ~120 server-rendered <img> cells with one compact array. #}
  <script type="application/json" id="home-gallery-data">{{ {
    images: all_images|map(i => {
      id: i.id,
      album_slug: i.album_slug,
      album_title: i.album_title,
      alt: i.alt|default(i.alt_text)|default(''),
      width: i.width,
      height: i.height,
      fallback_src: i.fallback_src|default(i.url)|default(''),
      sources: i.sources|default({})
    }),
    o2: o2,
    o3: o3,
    repeat: repeat_times,
    seed: seed_count,
    isHorizontal: (scroll_direction == 'horizontal'),
  }|json_encode|raw }}</script>

  {# No-JS fallback: without JS the desktop tracks would stay nearly empty, so
     show the (fully server-rendered) mobile list on desktop too. #}
  <noscript>
    <style>@media (min-width:768px){.home-mobile-wrap{display:block !important}.home-desktop-wrap{display:none !important}}</style>
  </noscript>
  {# Progressive loading config for JavaScript #}
  {% if has_more_images|default(false) %}
  <script nonce="{{ csp_nonce() }}">
    window.homeLoaderConfig = {
      shownImageIds: {{ shown_image_ids|default([])|json_encode|raw }},
      shownAlbumIds: {{ shown_album_ids|default([])|json_encode|raw }},
      hasMore: true,
      basePath: {{ base_path|json_encode|raw }}
    };
  </script>
  {# Trigger element for IntersectionObserver - loads more when visible #}
  <div id="home-load-trigger" class="h-1 w-full pointer-events-none" aria-hidden="true"></div>
  {% endif %}
</section>
{% endif %}
