<!doctype html>
<html lang="{{ admin_locale|default('en')|slice(0, 2) }}"{% if dark_mode|default(false) %} class="dark"{% endif %}>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ trans('admin.login.title') }} — {{ site_title|default('Cimaise') }}</title>
  <link href="{{ vite_asset('app.css') }}" rel="stylesheet">
  {# admin-app.css carries the admin-purged Tailwind utilities (app.css is purged against frontend views only) #}
  <link href="{{ vite_asset('admin-app.css') }}" rel="stylesheet">
  <link href="{{ base_path }}/assets/vendor/fontawesome/css/all.min.css" rel="stylesheet">
  <link href="{{ base_path }}/fonts/typography.css" rel="stylesheet">

  <!-- Custom CSS (Frontend Only) -->
  {% if custom_css|default('') is not empty %}
  <style nonce="{{ csp_nonce() }}">
    /* ===== Custom CSS ===== */
    {{ custom_css|raw }}
  </style>
  {% endif %}

  <style nonce="{{ csp_nonce() }}">
    /* Split login. The left panel is the one committed visual element: the
       photographer's wordmark set in the site display font on a darkroom
       surface; the form stays on a quiet product surface. */
    .login-shell { min-height: 100vh; min-height: 100dvh; display: grid; grid-template-columns: 1fr; }
    @media (min-width: 1024px) { .login-shell { grid-template-columns: 5fr 4fr; } }

    .login-stage {
      position: relative;
      background: #101013; /* near-black, warm-tinted: the darkroom */
      color: #f5f4f2;
      display: flex; flex-direction: column; justify-content: space-between;
      padding: 2rem 2.25rem;
      overflow: hidden;
    }
    @media (min-width: 1024px) { .login-stage { padding: 3.5rem 4rem; } }
    /* a single, faint focus-frame line — photographic viewfinder, not decoration overload */
    .login-stage::after {
      content: '';
      position: absolute; inset: 18px;
      border: 1px solid rgba(245, 244, 242, 0.10);
      border-radius: 10px;
      pointer-events: none;
    }
    .login-wordmark {
      font-family: var(--font-headings, Georgia, serif);
      font-weight: 400;
      font-size: clamp(2.4rem, 5vw, 4.25rem);
      line-height: 1.05;
      letter-spacing: -0.015em;
      max-width: 14ch;
    }
    .login-kicker {
      font-size: 0.6875rem; letter-spacing: 0.22em; text-transform: uppercase;
      color: rgba(245, 244, 242, 0.55);
    }
    .login-stage-meta {
      display: flex; align-items: center; gap: 0.75rem;
      font-size: 0.75rem; color: rgba(245, 244, 242, 0.62);
      font-variant-numeric: tabular-nums;
    }
    .login-stage-meta .dot { width: 4px; height: 4px; border-radius: 9999px; background: var(--color-accent, #D70261); }

    .login-form-pane {
      background: var(--color-bg-primary, #F6F7F9);
      display: flex; align-items: center; justify-content: center;
      padding: 2.5rem 1.25rem;
    }
    /* The admin stylesheet's global `html.dark i` rule would freeze the
       password-toggle icon color; let the button's own utilities govern. */
    html.dark #togglePassword i { color: inherit; }
    .login-card { width: 100%; max-width: 24.5rem; }

    /* On small screens the stage becomes a compact masthead */
    @media (max-width: 1023.98px) {
      .login-stage { min-height: 11rem; }
      .login-stage::after { inset: 10px; }
      .login-wordmark { font-size: clamp(1.9rem, 8vw, 2.6rem); }
      .login-stage-bottom { display: none; }
    }
  </style>
</head>
<body>
  <div class="login-shell">

    {# ---- Stage: the photographer's brand carries the page ---- #}
    <section class="login-stage" aria-hidden="true">
      <div class="login-kicker">{{ site_title|default('Cimaise') }} · {{ trans('admin.login.admin_panel') }}</div>
      <div>
        {% if logo_type == 'image' and site_logo %}
          <img src="{% if site_logo starts with '/' %}{{ base_path }}{{ site_logo }}{% else %}{{ site_logo }}{% endif %}"
               alt="" class="h-14 w-auto">
        {% else %}
          <div class="login-wordmark">{{ site_title|default('Cimaise') }}</div>
        {% endif %}
      </div>
      <div class="login-stage-bottom login-stage-meta">
        <span>Cimaise</span><span class="dot"></span><span>{{ "now"|date('Y') }}</span>
      </div>
    </section>

    {# ---- Form pane ---- #}
    <main class="login-form-pane">
      <div class="login-card">
        <h1 class="text-xl font-semibold text-gray-900 dark:text-gray-100">{{ trans('admin.login.title') }}<span class="sr-only"> — {{ site_title|default('Cimaise') }}</span></h1>
        <p class="mt-1 mb-7 text-sm text-gray-500 dark:text-gray-400">{{ trans('admin.login.admin_panel') }}</p>

        {# Flash messages (e.g., session expired) #}
        {% if session.flash %}
        <div class="space-y-3 mb-5">
          {% for flash in session.flash %}
            <div role="alert" class="{% if flash.type == 'warning' %}bg-yellow-50 border border-yellow-200 text-yellow-800 dark:bg-yellow-950 dark:border-yellow-900 dark:text-yellow-200{% elseif flash.type == 'success' %}bg-green-50 border border-green-200 text-green-800 dark:bg-green-950 dark:border-green-900 dark:text-green-200{% else %}bg-red-50 border border-red-200 text-red-800 dark:bg-red-950 dark:border-red-900 dark:text-red-200{% endif %} px-4 py-3 rounded-lg text-sm">
              {{ flash.message|e }}
            </div>
          {% endfor %}
        </div>
        {% endif %}

        {% if error %}
          <div role="alert" class="mb-5 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-lg text-sm dark:bg-red-950 dark:border-red-900 dark:text-red-200">
            {{ error }}
          </div>
        {% endif %}

        {# Hook: login_before_form - For displaying info boxes like demo credentials #}
        {{ hook('login_before_form', {'base_path': base_path, 'csp_nonce': csp_nonce()}) }}

        <form method="post" action="{{ base_path }}/admin/login" class="space-y-5">
          <input type="hidden" name="csrf" value="{{ csrf }}">

          <div>
            <label for="email" class="block text-xs font-medium uppercase tracking-wider text-gray-600 dark:text-gray-400 mb-2">{{ trans('admin.login.email') }}</label>
            <input
              id="email"
              name="email"
              type="email"
              required
              autofocus
              autocomplete="username"
              class="block w-full px-3.5 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100 dark:placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent"
              placeholder="admin@cimaise.local"
            >
          </div>

          <div>
            <label for="password" class="block text-xs font-medium uppercase tracking-wider text-gray-600 dark:text-gray-400 mb-2">{{ trans('admin.login.password') }}</label>
            <div class="relative">
              <input
                id="password"
                name="password"
                type="password"
                required
                autocomplete="current-password"
                class="block w-full pl-3.5 pr-11 py-3 rounded-lg border border-gray-300 bg-white text-gray-900 placeholder:text-gray-400 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-100 dark:placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-accent-500 focus:border-transparent"
                placeholder="••••••••"
              >
              <button
                type="button"
                id="togglePassword"
                aria-label="{{ trans('admin.login.toggle_password', {}, 'Show/hide password') }}"
                aria-pressed="false"
                class="absolute inset-y-0 right-0 px-3.5 flex items-center text-gray-500 hover:text-accent-600 focus:text-accent-600 focus:outline-none dark:text-gray-400 dark:hover:text-accent-400 dark:focus:text-accent-400"
              >
                <i class="fas fa-eye" id="togglePasswordIcon" aria-hidden="true"></i>
              </button>
            </div>
          </div>

          <div class="flex items-center pt-1">
            <label for="remember_me" class="inline-flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300 select-none">
              <input
                id="remember_me"
                name="remember_me"
                type="checkbox"
                value="1"
                class="h-4 w-4 text-accent-600 border-gray-300 rounded focus:ring-accent-500 dark:border-gray-600 dark:bg-gray-900"
              >
              {{ trans('admin.login.remember_me') }}
            </label>
          </div>

          <button
            type="submit"
            class="w-full bg-accent-600 hover:bg-accent-700 text-white font-medium py-3 px-4 rounded-lg transition-colors focus:outline-none focus:ring-2 focus:ring-accent-500 focus:ring-offset-2 dark:focus:ring-offset-[#0f1115]"
          >
            {{ trans('admin.login.submit') }}
          </button>
        </form>

        <p class="mt-8 text-center text-xs text-gray-500 dark:text-gray-400">Cimaise</p>
      </div>
    </main>
  </div>

  <script nonce="{{ csp_nonce() }}">
    (function () {
      var btn = document.getElementById('togglePassword');
      var input = document.getElementById('password');
      var icon = document.getElementById('togglePasswordIcon');
      if (!btn || !input) return;
      btn.addEventListener('click', function () {
        var reveal = input.type === 'password';
        input.type = reveal ? 'text' : 'password';
        btn.setAttribute('aria-pressed', reveal ? 'true' : 'false');
        if (icon) {
          icon.classList.toggle('fa-eye', !reveal);
          icon.classList.toggle('fa-eye-slash', reveal);
        }
        input.focus();
      });
    })();
  </script>
</body>
</html>
