{% extends 'admin/_layout.twig' %}
{% block title %}{{ trans('admin.dashboard.title') }} — Cimaise{% endblock %}
{% block content %}
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">{{ trans('admin.dashboard.title') }}</h1>
      <p class="text-gray-600 mt-1">{{ trans('admin.dashboard.welcome') }}{% if userName %}, {{ userName }}{% endif %}!</p>
    </div>
    <a href="{{ base_path }}/admin/albums/create" class="btn-primary"><i class="fas fa-plus mr-2"></i>{{ trans('admin.dashboard.new_album') }}</a>
  </div>

  {# Analytics snapshot (hidden when analytics is disabled / has no data) #}
  {% if analytics %}
  <div class="card mb-6" style="padding:0">
    <div class="flex items-center justify-between px-5 py-4" style="border-bottom:1px solid var(--color-border)">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500">Analytics</h2>
      <a href="{{ base_path }}/admin/analytics" class="text-sm font-medium" style="color:var(--color-accent)">Apri analytics →</a>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3">
      <div class="px-5 py-5 grid grid-cols-2 gap-y-4 gap-x-3">
        <div><p class="text-xs uppercase tracking-wider text-gray-500">Pageview 24h</p><p class="font-serif text-2xl text-gray-900 mt-1 leading-none">{{ analytics.realtime.pageviews_24h|default(0) }}</p></div>
        <div><p class="text-xs uppercase tracking-wider text-gray-500">Sessioni attive</p><p class="font-serif text-2xl text-gray-900 mt-1 leading-none">{{ analytics.realtime.active_sessions|default(0) }}</p></div>
        <div><p class="text-xs uppercase tracking-wider text-gray-500">Pageview 7gg</p><p class="font-serif text-2xl text-gray-900 mt-1 leading-none">{{ analytics.pv7 }}</p></div>
        <div><p class="text-xs uppercase tracking-wider text-gray-500">Sessioni 7gg</p><p class="font-serif text-2xl text-gray-900 mt-1 leading-none">{{ analytics.sess7 }}</p></div>
      </div>
      <div class="px-5 py-5 lg:col-span-2" style="border-top:1px solid var(--color-border)">
        <p class="text-xs uppercase tracking-wider text-gray-500 mb-3">Pageview · ultimi 7 giorni</p>
        {% if analytics.series %}
        <div class="flex items-end gap-2">
          {% for d in analytics.series %}
          <div class="flex-1 flex flex-col items-center">
            <div class="w-full flex items-end justify-center" style="height:84px">
              <div title="{{ d.date }}: {{ d.pv }} pageview · {{ d.sessions }} sessioni" style="width:100%; min-height:2px; height:{{ (d.pv / analytics.max_pv * 100)|round }}%; background:var(--color-accent); border-radius:6px 6px 0 0"></div>
            </div>
            <span class="text-gray-400 mt-1" style="font-size:10px">{{ d.date|date('d/m') }}</span>
          </div>
          {% endfor %}
        </div>
        {% else %}
        <p class="text-sm text-gray-500">Nessun dato giornaliero ancora aggregato (gira <code>analytics:summarize</code>).</p>
        {% endif %}
      </div>
    </div>
    {% if analytics.top_pages %}
    <div class="px-5 py-4" style="border-top:1px solid var(--color-border)">
      <p class="text-xs uppercase tracking-wider text-gray-500 mb-3">Pagine più viste (ultimi 7 giorni)</p>
      <div class="space-y-2">
        {% for p in analytics.top_pages %}
        <div class="flex items-center justify-between text-sm gap-4">
          <span class="truncate text-gray-700">{{ p.page_title|default(p.page_url)|default('—') }}</span>
          <span class="font-medium text-gray-900 flex-none">{{ p.views }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
  {% endif %}

  {# KPI stat blocks — real counts from the database #}
  <div class="grid grid-cols-2 md:grid-cols-3 xl:grid-cols-6 gap-4 mb-6">
    <a href="{{ base_path }}/admin/albums" class="card p-5 hover:bg-gray-50 transition">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{{ trans('admin.dashboard.albums') }}</p>
      <p class="font-serif text-3xl text-gray-900 mt-2 leading-none">{{ stats.albums|default(0) }}</p>
      <p class="text-xs text-gray-500 mt-2">{{ stats.published|default(0) }} pubbl. · {{ stats.drafts|default(0) }} bozze</p>
    </a>
    <a href="{{ base_path }}/admin/media" class="card p-5 hover:bg-gray-50 transition">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">Foto</p>
      <p class="font-serif text-3xl text-gray-900 mt-2 leading-none">{{ stats.photos|default(0) }}</p>
      <p class="text-xs text-gray-500 mt-2">immagini in libreria</p>
    </a>
    <div class="card p-5" style="background: var(--color-accent); color: var(--color-accent-contrast); border-color: var(--color-accent);">
      <p class="text-xs font-semibold uppercase tracking-wider" style="opacity:.72">Spazio usato</p>
      <p class="font-serif text-3xl mt-2 leading-none">{{ stats.storage_human|default('0 MB') }}</p>
      <p class="text-xs mt-2" style="opacity:.72">varianti generate</p>
    </div>
    <a href="{{ base_path }}/admin/categories" class="card p-5 hover:bg-gray-50 transition">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{{ trans('admin.dashboard.categories') }}</p>
      <p class="font-serif text-3xl text-gray-900 mt-2 leading-none">{{ stats.categories|default(0) }}</p>
    </a>
    <a href="{{ base_path }}/admin/collections" class="card p-5 hover:bg-gray-50 transition">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{{ trans('admin.sidebar.collections') }}</p>
      <p class="font-serif text-3xl text-gray-900 mt-2 leading-none">{{ stats.collections|default(0) }}</p>
    </a>
    <a href="{{ base_path }}/admin/tags" class="card p-5 hover:bg-gray-50 transition">
      <p class="text-xs font-semibold uppercase tracking-wider text-gray-500">{{ trans('admin.dashboard.tags') }}</p>
      <p class="font-serif text-3xl text-gray-900 mt-2 leading-none">{{ stats.tags|default(0) }}</p>
    </a>
  </div>

  {# Recent albums #}
  {% if recentAlbums is defined and recentAlbums %}
  <div class="card overflow-hidden mb-6" style="padding:0">
    <div class="flex items-center justify-between px-5 py-4" style="border-bottom:1px solid var(--color-border)">
      <h2 class="text-xs font-semibold uppercase tracking-wider text-gray-500">Ultimi album aggiornati</h2>
      <a href="{{ base_path }}/admin/albums" class="text-sm font-medium" style="color:var(--color-accent)">Tutti gli album →</a>
    </div>
    <div>
      {% for al in recentAlbums %}
      <a href="{{ base_path }}/admin/albums/{{ al.id }}/edit" class="flex items-center gap-4 px-5 py-3 hover:bg-gray-50 transition" {% if not loop.first %}style="border-top:1px solid var(--color-border)"{% endif %}>
        {% if al.cover_path %}
          <img src="{% if al.cover_path starts with '/' %}{{ base_path }}{{ al.cover_path }}{% else %}{{ al.cover_path }}{% endif %}" alt="" class="w-12 h-9 object-cover rounded flex-none" style="border:1px solid var(--color-border)">
        {% else %}
          <span class="w-12 h-9 rounded flex-none flex items-center justify-center text-gray-400" style="background:var(--color-bg-tertiary)"><i class="fas fa-image"></i></span>
        {% endif %}
        <span class="flex-1 min-w-0">
          <span class="block font-medium text-gray-900 truncate">{{ al.title }}</span>
          <span class="block text-xs text-gray-500 truncate">{{ al.slug }}</span>
        </span>
        {% if al.is_published %}
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full" style="background:var(--color-accent-soft); color:var(--color-accent)">Pubblicato</span>
        {% else %}
          <span class="text-xs font-semibold px-2.5 py-1 rounded-full text-gray-500" style="background:var(--color-bg-tertiary)">Bozza</span>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# Quick actions toolbar #}
  <div class="card p-4 mb-6">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm font-semibold text-gray-500 mr-2">{{ trans('admin.dashboard.quick_actions') }}</span>
      <a href="{{ base_path }}/" target="_blank" rel="noopener" class="btn-secondary"><i class="fas fa-external-link-alt mr-2"></i>{{ trans('admin.dashboard.view_site') }}</a>
      <a href="{{ base_path }}/admin/media" class="btn-secondary"><i class="fas fa-images mr-2"></i>{{ trans('admin.sidebar.gallery') }}</a>
      <a href="{{ base_path }}/admin/pages" class="btn-secondary"><i class="fas fa-file-alt mr-2"></i>{{ trans('admin.sidebar.pages') }}</a>
      <a href="{{ base_path }}/admin/typography" class="btn-secondary"><i class="fas fa-font mr-2"></i>{{ trans('admin.sidebar.typography') }}</a>
      <a href="{{ base_path }}/admin/settings" class="btn-secondary"><i class="fas fa-cog mr-2"></i>{{ trans('admin.sidebar.settings') }}</a>
      <button type="button" id="dash-flush-cache" class="btn-secondary ml-auto"><i class="fas fa-broom mr-2"></i>{{ trans('admin.dashboard.clear_cache') }}</button>
      <span id="dash-cache-msg" class="text-sm text-green-600" role="status" aria-live="polite"></span>
    </div>
  </div>
  <script nonce="{{ csp_nonce() }}">
    (function(){
      var btn = document.getElementById('dash-flush-cache');
      var msg = document.getElementById('dash-cache-msg');
      if (!btn) return;
      btn.addEventListener('click', function(){
        btn.disabled = true; if (msg) { msg.className = 'text-sm text-gray-500'; msg.textContent = '…'; }
        fetch('{{ base_path }}/admin/cache/clear', {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json', 'X-CSRF-Token': {{ csrf|json_encode|raw }} },
          credentials: 'same-origin'
        }).then(function(r){ if (!r.ok) throw new Error('cache-clear-failed'); return r.json(); })
          .then(function(d){ if (msg) { msg.className = 'text-sm text-green-600'; msg.textContent = (d && d.message) ? d.message : '{{ trans('admin.dashboard.cache_done')|e('js') }}'; } })
          .catch(function(){ if (msg) { msg.className = 'text-sm text-red-600'; msg.textContent = 'Error'; } })
          .then(function(){ btn.disabled = false; setTimeout(function(){ if (msg) msg.textContent = ''; }, 4000); });
      });
    })();
  </script>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/albums">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.albums') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.albums_desc') }}</p>
        </div>
        <i class="fas fa-images text-2xl text-gray-400"></i>
      </div>
    </a>
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/categories">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.categories') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.categories_desc') }}</p>
        </div>
        <i class="fas fa-folder-open text-2xl text-gray-400"></i>
      </div>
    </a>
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/tags">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.tags') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.tags_desc') }}</p>
        </div>
        <i class="fas fa-hashtag text-2xl text-gray-400"></i>
      </div>
    </a>
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/cameras">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.cameras') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.cameras_desc') }}</p>
        </div>
        <i class="fas fa-camera text-2xl text-gray-400"></i>
      </div>
    </a>
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/lenses">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.lenses') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.lenses_desc') }}</p>
        </div>
        <i class="fas fa-eye text-2xl text-gray-400"></i>
      </div>
    </a>
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/films">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.films') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.films_desc') }}</p>
        </div>
        <i class="fas fa-film text-2xl text-gray-400"></i>
      </div>
    </a>
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/developers">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.developers') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.developers_desc') }}</p>
        </div>
        <i class="fas fa-flask text-2xl text-gray-400"></i>
      </div>
    </a>
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/labs">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.labs') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.labs_desc') }}</p>
        </div>
        <i class="fas fa-industry text-2xl text-gray-400"></i>
      </div>
    </a>
    <a class="card p-6 hover:bg-gray-50 transition" href="{{ base_path }}/admin/commands">
      <div class="flex items-center justify-between">
        <div>
          <h3 class="text-lg font-medium text-gray-900">{{ trans('admin.dashboard.tools') }}</h3>
          <p class="text-gray-600 text-sm">{{ trans('admin.dashboard.tools_desc') }}</p>
        </div>
        <i class="fas fa-wrench text-2xl text-gray-400"></i>
      </div>
    </a>
  </div>
{% endblock %}
